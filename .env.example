# HTTP Server Configuration
HTTP_PROXY_HOST=0.0.0.0
HTTP_PROXY_PORT=4195

# Kafka Configuration
KAFKA_BROKERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_TLS_ENABLED=true
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_API_KEY=your-api-key
KAFKA_API_SECRET=your-api-secret
KAFKA_CLIENT_ID=bento-http-kafka-proxy

# Schema Registry Configuration
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-1.aws.confluent.cloud
SCHEMA_REGISTRY_USERNAME=your-sr-api-key
SCHEMA_REGISTRY_PASSWORD=your-sr-api-secret

# Logging Configuration
LOG_LEVEL=DEBUG

# Performance Tuning
# Default: Balanced (100 msgs, 1MB, 100ms, snappy, max_in_flight=10)
# High Throughput: KAFKA_MAX_IN_FLIGHT=50, KAFKA_BATCH_COUNT=500, KAFKA_BATCH_SIZE=5000000, KAFKA_BATCH_PERIOD=200ms, KAFKA_COMPRESSION=lz4
# Low Latency: KAFKA_MAX_IN_FLIGHT=1, KAFKA_BATCH_COUNT=10, KAFKA_BATCH_SIZE=100000, KAFKA_BATCH_PERIOD=10ms, KAFKA_COMPRESSION=none
KAFKA_MAX_IN_FLIGHT=10
KAFKA_BATCH_COUNT=100
KAFKA_BATCH_SIZE=1000000
KAFKA_BATCH_PERIOD=100ms
KAFKA_COMPRESSION=snappy
